{
  "name": "402-announce",
  "version": "1.3.0",
  "type": "module",
  "description": "Announce HTTP 402 services (L402 and x402) on Nostr for decentralised discovery. Kind 31402 parameterised replaceable events.",
  "license": "MIT",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "files": [
    "build",
    "LICENSE",
    "README.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "nostr-tools": "^2.12.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/node": "^25.5.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "l402",
    "x402",
    "402",
    "nostr",
    "discovery",
    "lightning",
    "cashu",
    "mcp",
    "ai-agents",
    "machine-payments",
    "http-402"
  ],
  "homepage": "https://github.com/TheCryptoDonkey/402-announce",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCryptoDonkey/402-announce.git"
  },
  "engines": {
    "node": ">=18"
  }
}
