{
  "name": "@thecryptodonkey/l402-announce",
  "version": "0.0.1",
  "type": "module",
  "description": "Announce L402 services on Nostr for decentralised discovery. Kind 31402 parameterised replaceable events.",
  "license": "MIT",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "files": ["build", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "nostr-tools": "^2.12.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "l402", "nostr", "discovery", "lightning", "cashu",
    "mcp", "ai-agents", "machine-payments", "http-402"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TheCryptoDonkey/l402-announce.git"
  },
  "engines": { "node": ">=18" }
}
